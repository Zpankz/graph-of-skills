# ──────────────────────────────────────────────────────────────────────────────
# Graph of Skills — Environment Configuration
# Copy this file to .env and fill in your API keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── GoS core settings ────────────────────────────────────────────────────────
GOS_WORKING_DIR=./gos_workspace
GOS_PREBUILT_WORKING_DIR=

# Default LLM for extraction + link inference.
# gemini-3.1-flash-lite-preview is the recommended production model:
#   • Completes a 98-skill graph in ~2 min (vs. 18+ min with 2.5-flash on free-tier
#     keys, which repeatedly stalls on rate limits)
#   • Delivers strong dependency/workflow edge quality at one LLM call per skill
# Override only if you have a paid, high-quota key for a stronger model.
GOS_LLM_MODEL=gemini/gemini-3.1-flash-lite-preview

# ── Embedding provider (pick ONE section below) ─────────────────────────────
# The embedding model and dimension must match between indexing and retrieval.
# Code defaults: GOS_EMBEDDING_MODEL=openai/text-embedding-3-large, GOS_EMBEDDING_DIM=3072

# Option A: OpenAI API (matches code defaults; set OPENAI_API_KEY; leave OPENAI_BASE_URL unset)
# OPENAI_API_KEY=your-openai-api-key
# GOS_EMBEDDING_MODEL=openai/text-embedding-3-large
# GOS_EMBEDDING_DIM=3072

# Option B: Google Gemini (single-key setup: LLM + embeddings via the same GEMINI_API_KEY)
# GEMINI_API_KEY=your-gemini-api-key
# GOS_EMBEDDING_MODEL=gemini/gemini-embedding-2-preview
# GOS_EMBEDDING_DIM=3072

# Option C: OpenRouter (explicit ``openrouter/...`` prefix routes via OpenRouter API)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENAI_API_KEY=optional-fallback-same-as-openrouter-key
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# GOS_EMBEDDING_MODEL=openrouter/openai/text-embedding-3-large
# GOS_EMBEDDING_DIM=3072

# Option D: Azure AI / any OpenAI-compatible URL (no OpenRouter prefix)
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/openai/v1
# Use the deployment name your resource exposes (often not ``text-embedding-3-large``).
# GOS_EMBEDDING_MODEL=openai/embed-v-4-0
# GOS_EMBEDDING_DIM=1536
# (OPENROUTER_API_KEY in the environment is ignored for non-openrouter.ai bases.)

# ── Additional API keys (for evaluation tracks) ─────────────────────────────
# OPENROUTER_API_KEY=your-openrouter-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Retrieval tuning (optimised for graph reasoning) ────────────────────────
# These defaults are tuned for denser, higher-recall retrieval than the bare
# library defaults. They are what ship in production GoS workspaces.

# Denser edges during indexing: each skill considers more candidates for linking.
# 10 is +25% vs the library default (8) and keeps LLM call volume tractable on
# rate-limited Gemini keys.
GOS_LINK_TOP_K=10

# Wider seed pool before PPR expansion; richer per-skill body for rerank / context.
GOS_SEED_TOP_K=8
GOS_RETRIEVAL_TOP_N=10
GOS_MAX_SKILL_CHARS=3200
GOS_MAX_CONTEXT_CHARS=20000

# Wider initial candidate net for seed selection (semantic + lexical).
GOS_SEED_CANDIDATE_TOP_K_SEMANTIC=40
GOS_SEED_CANDIDATE_TOP_K_LEXICAL=40

# Larger rerank pool: more candidates scored before the final cut.
GOS_RERANK_CANDIDATE_MULTIPLIER=4

# Slightly looser dependency threshold → more legitimate edges while keeping
# precision above ~0.5. Tested against the 98-skill obsidian-skills corpus: this
# setting yields +7% edges vs. the default 0.6 threshold.
GOS_DEPENDENCY_MATCH_THRESHOLD=0.55

# Full-markdown embeddings (body + metadata) for stronger semantic matching.
GOS_USE_FULL_MARKDOWN=true
GOS_ENABLE_SEMANTIC_LINKING=true

# LLM query rewrite expands ambiguous task descriptions → large recall improvement.
GOS_ENABLE_QUERY_REWRITE=true

# Richer snippets shown in summaries.
GOS_SNIPPET_CHARS=1400
